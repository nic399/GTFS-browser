# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eslint
.eslintcache

# sqlite / local gtfs data (see app/config.json sqlitePath)
# Ignore arbitrary DBs by default; commit the bundled GTFS DB.
*.db
!app/gtfs.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# IDE / editors
.idea/
*.swp
*.swo
*~
